# ============================================================
# FishWeather - Configuration des clés API
# Copier ce fichier en .env.local et renseigner vos clés
# NE JAMAIS committer .env.local !
# ============================================================

# --- OpenWeatherMap (obligatoire pour météo basique) ---
# Inscription gratuite sur : https://openweathermap.org/api
# Plan gratuit : 1000 appels/jour
VITE_OWM_API_KEY=your_owm_api_key_here

# --- Météo-France Portail API (AROME, ARPEGE, Bulletins côtiers) ---
# Inscription sur : https://portail-api.meteofrance.fr
# Inclut : AROME 2.5km, AROME HD 1.3km, ARPEGE 10km, Bulletins côtiers
VITE_MF_API_KEY=your_meteofrance_api_key_here

# --- Copernicus Marine Service (vagues, courants, T° mer) ---
# Inscription sur : https://marine.copernicus.eu
# Données haute résolution Atlantique/Méditerranée
VITE_COPERNICUS_USERNAME=your_copernicus_username
VITE_COPERNICUS_PASSWORD=your_copernicus_password

# --- MapTiler (styles vectoriels MapLibre) ---
# Inscription gratuite sur : https://www.maptiler.com
# Plan gratuit : 100k tiles/mois
VITE_MAPTILER_KEY=your_maptiler_key_here

# --- SHOM (cartes marines + marées) ---
# Clé API SHOM pour les tuiles WMTS (cartes marines françaises)
# Inscription sur : https://services.data.shom.fr
# Les prédictions de marées WPS sont accessibles sans clé
VITE_SHOM_API_KEY=your_shom_api_key_here

# ============================================================
# APIs GRATUITES (sans clé) :
# - Open-Meteo (météo + marine) : https://open-meteo.com
# - Vigicrues / Hub'Eau : https://hubeau.eaufrance.fr
# - OpenStreetMap / Nominatim
# - OpenSeaMap
# - API Géo France : https://geo.api.gouv.fr
# ============================================================

# --- Feature flags ---
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_MARINE=true
VITE_MAX_OFFLINE_TILES=2000
